    "instrumental",
    "cover",
    "lyrics",
    "track",
    "audio"
  ],
  "triggers": [
    "make me a song",
    "generate a track",
    "create an instrumental",
    "make a cover from this audio"
  ],
  "requiresTools": [],
  "dependsOn": [],
  "composes": [],
  "sideEffects": true,
  "hooks": {
    "beforeRun": "hooks/before-run.js"
  },
  "actions": [
    "compose",
    "draft-lyrics"
  ]
}
